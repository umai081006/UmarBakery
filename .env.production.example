# =======================================================
# UMAR BAKERY — PRODUCTION ENVIRONMENT TEMPLATE
# =======================================================
# USAGE: Copy this file to .env on your production server
#        and REPLACE all placeholder values with real ones.
#        DO NOT commit the real .env to version control.
# =======================================================

# -------------------------------------------------------
# APPLICATION
# -------------------------------------------------------
APP_NAME="Umar Bakery"
APP_ENV=production
APP_KEY=                    # Run: php artisan key:generate
APP_DEBUG=false
APP_URL=https://yourdomain.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# -------------------------------------------------------
# BCRYPT
# -------------------------------------------------------
BCRYPT_ROUNDS=12

# -------------------------------------------------------
# LOGGING
# -------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error           # Change to 'debug' ONLY when troubleshooting

# -------------------------------------------------------
# DATABASE (PostgreSQL)
# -------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=umar_bakery
DB_USERNAME=              # Your production DB username
DB_PASSWORD=              # Your production DB password

# -------------------------------------------------------
# SESSION
# -------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.yourdomain.com   # Set to production domain

# -------------------------------------------------------
# BROADCASTING
# -------------------------------------------------------
BROADCAST_CONNECTION=log

# -------------------------------------------------------
# FILESYSTEM
# -------------------------------------------------------
FILESYSTEM_DISK=local

# -------------------------------------------------------
# QUEUE
# -------------------------------------------------------
QUEUE_CONNECTION=database  # Recommended: switch to 'redis' for high traffic
# See: docs/supervisor.conf for worker setup

# -------------------------------------------------------
# CACHE
# -------------------------------------------------------
CACHE_STORE=database       # Recommended: switch to 'redis' for high traffic

# -------------------------------------------------------
# REDIS (Optional — activate if switching queue/cache to redis)
# -------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -------------------------------------------------------
# MAIL (Required — replace with your SMTP provider)
# -------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.yourmailprovider.com
MAIL_PORT=587
MAIL_USERNAME=             # Your SMTP username
MAIL_PASSWORD=             # Your SMTP password
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# -------------------------------------------------------
# CLOUDINARY
# -------------------------------------------------------
CLOUDINARY_CLOUD_NAME=     # Your Cloudinary cloud name
CLOUDINARY_API_KEY=        # Your Cloudinary API key
CLOUDINARY_API_SECRET=     # Your Cloudinary API secret

# -------------------------------------------------------
# MIDTRANS (PRODUCTION)
# -------------------------------------------------------
MIDTRANS_SERVER_KEY=       # Your PRODUCTION Server Key from Midtrans Dashboard
MIDTRANS_CLIENT_KEY=       # Your PRODUCTION Client Key from Midtrans Dashboard
MIDTRANS_IS_PRODUCTION=true
MIDTRANS_SANITIZATION=true
MIDTRANS_3DS=true

# -------------------------------------------------------
# VITE
# -------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
